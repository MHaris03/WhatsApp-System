# MongoDB Atlas connection string (required).
# Get it from Atlas: Cluster → Connect → Drivers → copy the SRV string.
# Replace <username> and <password> with your database user's credentials.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Database name. Defaults to "WhatsApp-System" (matches your Atlas database).
# MONGODB_DB=WhatsApp-System

# Collection name. ALL data (contacts + chats + messages) is stored here.
# Defaults to "WhatsApp-Chat".
# MONGODB_COLLECTION=WhatsApp-Chat

# Country code added to LOCAL numbers written with a leading 0 (e.g. a Pakistani
# mobile "0333-6667777" becomes "923336667777"). Defaults to 92 (Pakistan).
# DEFAULT_COUNTRY_CODE=92

# ---- Multi-user auth ----
# Secret used to sign login tokens (JWT). Set a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string
# How long a login stays valid.
# JWT_EXPIRES=7d
# Max users with an ACTIVE WhatsApp session at the same time (4th gets "server full").
# MAX_ACTIVE_SESSIONS=3

# Optional: backend port (defaults to 4000).
# PORT=4000
